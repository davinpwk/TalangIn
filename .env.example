# ─── Telegram ───────────────────────────────────────────────────────────────
# Your bot token from BotFather (required)
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmNOPQRSTuvwxyz

# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite file (relative to project root)
DB_PATH=./data/db.sqlite

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Max messages per window per user
RATE_LIMIT_MAX=30
# Window in milliseconds (default: 60 seconds)
RATE_LIMIT_WINDOW_MS=60000

# ─── OPTIONAL: Staging bot ───────────────────────────────────────────────────
# Uncomment and set a separate bot token for a dev/staging environment.
# Run a second instance with NODE_ENV=development pointing to a dev DB.
# TELEGRAM_BOT_TOKEN=<staging-token>
# DB_PATH=./data/dev.sqlite
